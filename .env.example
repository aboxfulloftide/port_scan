DATABASE_URL=mysql+pymysql://user:password@localhost:3306/port_scan
JWT_SECRET=generate-a-long-random-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7
SCREENSHOT_DIR=/path/to/port_scan/screenshots

# DHCP hostname scraper (TP-Link router)
# Logs into the router via Playwright, fetches DHCP client table via stok-authenticated API.
# Leave ROUTER_URL blank to disable.
ROUTER_URL=https://192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=
DHCP_SCRAPE_INTERVAL_MIN=30
